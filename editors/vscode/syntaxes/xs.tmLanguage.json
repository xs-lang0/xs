{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "XS",
  "scopeName": "source.xs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#function-declaration" },
    { "include": "#tag-declaration" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.xs",
          "match": "--.*$"
        },
        {
          "name": "comment.block.xs",
          "begin": "\\{-",
          "end": "-\\}"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.xs",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            {
              "name": "constant.character.escape.xs",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.xs",
              "contentName": "source.xs.embedded",
              "begin": "(?<!\\\\)\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.xs" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.xs" } },
              "patterns": [{ "include": "source.xs" }]
            }
          ]
        },
        {
          "name": "string.quoted.raw.xs",
          "begin": "r\"",
          "end": "\""
        },
        {
          "name": "string.quoted.color.xs",
          "begin": "c\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xs",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.xs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.xs",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.xs",
              "contentName": "source.xs.embedded",
              "begin": "(?<!\\\\)\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.xs" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.xs" } },
              "patterns": [{ "include": "source.xs" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.xs",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.xs",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.xs",
              "contentName": "source.xs.embedded",
              "begin": "(?<!\\\\)\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.xs" } },
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.xs" } },
              "patterns": [{ "include": "source.xs" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.xs",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.octal.xs",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.binary.xs",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.xs",
          "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?([eE][+-]?[0-9_]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xs",
          "match": "\\b(if|else|elif|while|for|in|loop|match|when|return|break|continue|try|catch|finally|throw|defer|yield|async|await)\\b"
        },
        {
          "name": "keyword.declaration.xs",
          "match": "\\b(fn|let|var|const|struct|enum|trait|impl|class|type|macro|tag)\\b"
        },
        {
          "name": "keyword.import.xs",
          "match": "\\b(import|export|from|use|module|as)\\b"
        },
        {
          "name": "keyword.operator.logical.xs",
          "match": "\\b(and|or|not|is)\\b"
        },
        {
          "name": "keyword.other.xs",
          "match": "\\b(pub|mut|static|inline|unsafe|effect|perform|handle|resume|spawn|nursery|actor)\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "\\b(fn\\*?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[(<]",
          "captures": {
            "1": { "name": "keyword.declaration.xs" },
            "2": { "name": "entity.name.function.xs" }
          }
        }
      ]
    },
    "tag-declaration": {
      "patterns": [
        {
          "match": "\\b(tag)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*[({]",
          "captures": {
            "1": { "name": "keyword.declaration.xs" },
            "2": { "name": "entity.name.function.xs" }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.xs",
          "match": "\\b(print|println|eprint|eprintln|input|len|type|range|assert|assert_eq|panic|typeof|dbg|pprint|repr|exit|todo|unreachable|copy|clone|signal|derived)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.xs",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.xs",
          "match": "\\b(self|super)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.xs",
          "match": "\\b(int|i8|i16|i32|i64|u8|u16|u32|u64|float|f32|f64|str|string|bool|char|byte|re|any|dyn|void|unit|never)\\b"
        },
        {
          "name": "entity.name.type.xs",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.xs",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.xs",
          "match": "=>|->",
          "comment": "fat arrow and return type arrow"
        },
        {
          "name": "keyword.operator.range.xs",
          "match": "\\.\\.<|\\.\\.\\.|\\.\\."
        },
        {
          "name": "keyword.operator.power.xs",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.spaceship.xs",
          "match": "<=>"
        },
        {
          "name": "keyword.operator.null-coalesce.xs",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.concat.xs",
          "match": "\\+\\+"
        }
      ]
    }
  }
}
